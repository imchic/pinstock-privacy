import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:pinstock/config/index.dart';

import '../../../data/models/index.dart';
import '../../../providers/index.dart';


class FeedScreen extends ConsumerStatefulWidget {
  const FeedScreen({super.key});

  @override
  ConsumerState<FeedScreen> createState() => _FeedScreenState();
}

class _FeedScreenState extends ConsumerState<FeedScreen> {
  int _selectedTabIndex = 0;
  String selectedRegion = '전체';
  final regions = ['전체', '미국', '유럽', '아시아', '한국'];

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: AppColors.bg,
      body: CustomScrollView(
        slivers: [
          SliverAppBar(
            expandedHeight: 80,
            floating: true,
            pinned: true,
            elevation: 0,
            scrolledUnderElevation: 0,
            backgroundColor: AppColors.bg,
            flexibleSpace: FlexibleSpaceBar(
              background: Container(
                decoration: BoxDecoration(
                  color: AppColors.bg,
                  boxShadow: [
                    BoxShadow(color: Colors.black.withAlpha(30), blurRadius: 8, offset: const Offset(0, 2))
                  ],
                ),
                child: Padding(
                  padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 16),
                  child: Column(
                    mainAxisAlignment: MainAxisAlignment.end,
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: const [
                      Text('뉴스 피드', style: TextStyle(color: AppColors.textPrimary, fontWeight: FontWeight.w700, fontSize: 26)),
                      SizedBox(height: 4),
                      Text('센티멘트별 금융 뉴스', style: TextStyle(color: AppColors.textSecondary, fontSize: 13)),
                    ],
                  ),
                ),
              ),
            ),
          ),
          // 탭 바
          SliverToBoxAdapter(
            child: Container(
              color: AppColors.surface,
              child: Column(
                children: [
                  SingleChildScrollView(
                    scrollDirection: Axis.horizontal,
                    child: Row(
                      children: [
                        _buildTab('전체', 0),
                        _buildTab('호재', 1),
                        _buildTab('악재', 2),
                        _buildTab('중립', 3),
                      ],
                    ),
                  ),
                  Container(height: 1, color: AppColors.border),
                  Padding(
                    padding: const EdgeInsets.all(16),
                    child: _FilterBar(
                      regions: regions,
                      selectedRegion: selectedRegion,
                      onRegionChanged: (region) {
                        setState(() => selectedRegion = region);
                        ref.read(selectedRegionProvider.notifier).state = region;
                      },
                    ),
                  ),
                ],
              ),
            ),
          ),
          // 콘텐츠
          SliverToBoxAdapter(
            child: Padding(
              padding: const EdgeInsets.fromLTRB(16, 0, 16, 16),
              child: _buildTabContent(),
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildTab(String label, int index) {
    final isSelected = _selectedTabIndex == index;
    return GestureDetector(
      onTap: () => setState(() => _selectedTabIndex = index),
      child: Padding(
        padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
        child: Column(
          children: [
            Text(
              label,
              style: TextStyle(
                color: isSelected ? AppColors.accent : AppColors.textSecondary,
                fontWeight: isSelected ? FontWeight.bold : FontWeight.w600,
                fontSize: 14,
              ),
            ),
            const SizedBox(height: 8),
            if (isSelected)
              Container(
                height: 3,
                width: 24,
                decoration: BoxDecoration(
                  color: AppColors.accent,
                  borderRadius: BorderRadius.circular(2),
                ),
              ),
          ],
        ),
      ),
    );
  }

  Widget _buildTabContent() {
    switch (_selectedTabIndex) {
      case 0:
        return _buildAllNewsTab();
      case 1:
        return _buildPositiveNewsTab();
      case 2:
        return _buildNegativeNewsTab();
      case 3:
        return _buildNeutralNewsTab();
      default:
        return _buildAllNewsTab();
    }
  }

  Widget _buildAllNewsTab() {
    final filteredNewsAsync = ref.watch(filteredNewsProvider);

    return filteredNewsAsync.when(
      data: (news) {
        if (news.isEmpty) {
          return Center(
            child: Padding(
              padding: EdgeInsets.all(40),
              child: Text('뉴스가 없습니다.', style: TextStyle(color: AppColors.textSecondary)),
            ),
          );
        }
        return Column(
          children: List.generate(
            news.length,
            (index) => _NewsListItem(news: news[index]),
          ),
        );
      },
      loading: () => Center(
        child: Padding(
          padding: EdgeInsets.all(20),
          child: CircularProgressIndicator(valueColor: AlwaysStoppedAnimation<Color>(AppColors.accent)),
        ),
      ),
      error: (error, stack) => Center(
        child: Padding(
          padding: const EdgeInsets.all(20),
          child: Text('에러: $error', style: TextStyle(color: AppColors.red)),
        ),
      ),
    );
  }

  Widget _buildPositiveNewsTab() {
    final newsAsync = ref.watch(positiveSentimentNewsProvider);

    return newsAsync.when(
      data: (news) {
        if (news.isEmpty) {
          return Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Icon(Icons.trending_up, size: 48, color: AppColors.green.withAlpha(150)),
                const SizedBox(height: 12),
                Text('호재 뉴스가 없습니다.', style: TextStyle(color: AppColors.textSecondary, fontSize: 14)),
              ],
            ),
          );
        }
        return Column(
          children: List.generate(
            news.length,
            (index) => _NewsListItem(news: news[index]),
          ),
        );
      },
      loading: () => Center(
        child: CircularProgressIndicator(valueColor: AlwaysStoppedAnimation<Color>(AppColors.accent)),
      ),
      error: (error, stack) => Center(child: Text('에러: $error', style: TextStyle(color: AppColors.red))),
    );
  }

  Widget _buildNegativeNewsTab() {
    final newsAsync = ref.watch(negativeSentimentNewsProvider);

    return newsAsync.when(
      data: (news) {
        if (news.isEmpty) {
          return Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Icon(Icons.trending_down, size: 48, color: AppColors.red.withAlpha(150)),
                const SizedBox(height: 12),
                Text('악재 뉴스가 없습니다.', style: TextStyle(color: AppColors.textSecondary, fontSize: 14)),
              ],
            ),
          );
        }
        return Column(
          children: List.generate(
            news.length,
            (index) => _NewsListItem(news: news[index]),
          ),
        );
      },
      loading: () => Center(
        child: CircularProgressIndicator(valueColor: AlwaysStoppedAnimation<Color>(AppColors.accent)),
      ),
      error: (error, stack) => Center(child: Text('에러: $error', style: TextStyle(color: AppColors.red))),
    );
  }

  Widget _buildNeutralNewsTab() {
    final newsAsync = ref.watch(neutralSentimentNewsProvider);

    return newsAsync.when(
      data: (news) {
        if (news.isEmpty) {
          return Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Icon(Icons.trending_flat, size: 48, color: AppColors.accent.withAlpha(150)),
                const SizedBox(height: 12),
                Text('중립 뉴스가 없습니다.', style: TextStyle(color: AppColors.textSecondary, fontSize: 14)),
              ],
            ),
          );
        }
        return Column(
          children: List.generate(
            news.length,
            (index) => _NewsListItem(news: news[index]),
          ),
        );
      },
      loading: () => Center(
        child: CircularProgressIndicator(valueColor: AlwaysStoppedAnimation<Color>(AppColors.accent)),
      ),
      error: (error, stack) => Center(child: Text('에러: $error', style: TextStyle(color: AppColors.red))),
    );
  }
}

class _FilterBar extends StatelessWidget {
  final List<String> regions;
  final String selectedRegion;
  final Function(String)? onRegionChanged;

  const _FilterBar({
    required this.regions,
    required this.selectedRegion,
    this.onRegionChanged,
  });

  @override
  Widget build(BuildContext context) {
    return SingleChildScrollView(
      scrollDirection: Axis.horizontal,
      child: Row(
        children: regions.map((region) {
          final isSelected = selectedRegion == region;
          return Padding(
            padding: const EdgeInsets.only(right: 8),
            child: FilterChip(
              label: Text(region),
              selected: isSelected,
              onSelected: (selected) => selected ? onRegionChanged?.call(region) : null,
              backgroundColor: AppColors.surface,
              selectedColor: AppColors.accent.withAlpha(150),
              labelStyle: TextStyle(
                color: isSelected ? AppColors.accent : AppColors.textSecondary,
                fontSize: 12,
              ),
            ),
          );
        }).toList(),
      ),
    );
  }
}

class _NewsListItem extends ConsumerWidget {
  final News news;

  const _NewsListItem({required this.news});

  String _getImportanceLabel(int level) {
    const labels = ['', '낮음', '중간', '높음', '매우높음', '긴급'];
    return level >= 0 && level < labels.length ? labels[level] : '중간';
  }

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    return Container(
      margin: const EdgeInsets.only(bottom: 12),
      decoration: BoxDecoration(
        color: AppColors.surface,
        borderRadius: BorderRadius.circular(10),
        border: Border.all(color: AppColors.border, width: 1),
        boxShadow: [BoxShadow(color: Colors.black.withAlpha(15), blurRadius: 6, offset: const Offset(0, 2))],
      ),
      child: Padding(
        padding: const EdgeInsets.all(10),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Row(
              children: [
                Expanded(
                  child: Text(
                    news.title,
                    maxLines: 2,
                    overflow: TextOverflow.ellipsis,
                    style: TextStyle(fontWeight: FontWeight.w600, fontSize: 14, color: AppColors.textPrimary),
                  ),
                ),
                const SizedBox(width: 8),
                Container(
                  padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
                  decoration: BoxDecoration(
                    color: AppColors.accent.withAlpha(150),
                    borderRadius: BorderRadius.circular(4),
                  ),
                  child: Text(
                    _getImportanceLabel(news.importanceLevel),
                    style: TextStyle(color: AppColors.accent, fontWeight: FontWeight.bold, fontSize: 10),
                  ),
                ),
              ],
            ),
            const SizedBox(height: 8),
            Text(
              news.description,
              maxLines: 2,
              overflow: TextOverflow.ellipsis,
              style: TextStyle(fontSize: 12, color: AppColors.textSecondary),
            ),
            const SizedBox(height: 8),
            Row(
              children: [
                Expanded(
                  child: Wrap(
                    spacing: 4,
                    children: news.keywords.take(3).map((keyword) {
                      return Container(
                        padding: const EdgeInsets.symmetric(horizontal: 6, vertical: 2),
                        decoration: BoxDecoration(
                          color: AppColors.accent.withAlpha(80),
                          borderRadius: BorderRadius.circular(3),
                        ),
                        child: Text(
                          keyword,
                          style: TextStyle(fontSize: 10, color: AppColors.accent.withAlpha(255)),
                        ),
                      );
                    }).toList(),
                  ),
                ),
                const SizedBox(width: 8),
                IconButton(
                  icon: Icon(news.isBookmarked ? Icons.bookmark : Icons.bookmark_border),
                  color: news.isBookmarked ? AppColors.accent : AppColors.textSecondary,
                  onPressed: () => ref.read(toggleBookmarkProvider(news)),
                  iconSize: 20,
                  padding: EdgeInsets.zero,
                  constraints: const BoxConstraints(),
                ),
              ],
            ),
          ],
        ),
      ),
    );
  }
}
